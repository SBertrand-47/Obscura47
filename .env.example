# ─────────────────────────────────────────────────────────────────
# Obscura47 - Environment Configuration
# Copy this file to .env and adjust values for your setup.
# All variables are optional. Defaults are shown below.
# ─────────────────────────────────────────────────────────────────

# ── Bootstrap Registry ───────────────────────────────────────────
# URL that nodes use to register and discover peers across the internet.
# Point this to wherever you host the registry server.
OBSCURA_REGISTRY_URL=https://db.monmedjs.com
OBSCURA_REGISTRY_PORT=8470
OBSCURA_REGISTRY_PEER_TTL=120
OBSCURA_REGISTRY_HEARTBEAT_INTERVAL=30

# ── Network ──────────────────────────────────────────────────────
OBSCURA_PROXY_HOST=127.0.0.1
OBSCURA_PROXY_PORT=9047
OBSCURA_PROXY_RESP_PORT=9051

# ── Component Ports ──────────────────────────────────────────────
OBSCURA_NODE_LISTEN_PORT=5001
OBSCURA_EXIT_LISTEN_PORT=6000

# ── LAN Discovery (multicast) ───────────────────────────────────
OBSCURA_DISCOVERY_GROUP=239.255.255.250
OBSCURA_DISCOVERY_PORT=50000
OBSCURA_NODE_DISCOVERY_PORT=50002
OBSCURA_EXIT_DISCOVERY_PORT=50003
OBSCURA_DISCOVERY_INTERVAL=10
OBSCURA_PEER_EXPIRY_SECONDS=30

# ── Exit Health Monitoring ───────────────────────────────────────
OBSCURA_EXIT_HEALTH_INTERVAL=7
OBSCURA_EXIT_CONNECT_TIMEOUT=1.5
OBSCURA_EXIT_HEALTH_DECAY=0.9
OBSCURA_EXIT_HEALTH_RTT_ALPHA=0.5

# ── Exit Backoff ─────────────────────────────────────────────────
OBSCURA_EXIT_BLACKLIST_FAILS=3
OBSCURA_EXIT_FAIL_BACKOFF_BASE=5
OBSCURA_EXIT_FAIL_BACKOFF_MAX=60

# ── Tunnel Reliability ───────────────────────────────────────────
OBSCURA_FRAME_RETRY_ATTEMPTS=3
OBSCURA_FRAME_RETRY_BASE_DELAY_MS=50
OBSCURA_TUNNEL_MAX_SECONDS=120
OBSCURA_TUNNEL_MAX_BYTES=10485760
OBSCURA_TUNNEL_IDLE_SECONDS=30
OBSCURA_CLEANUP_INTERVAL_SECONDS=10

# ── Route ────────────────────────────────────────────────────────
OBSCURA_MESSAGE_ROUTE_RETRIES=3

# ── Exit DNS & Privacy Policy ────────────────────────────────────
OBSCURA_EXIT_DOH_ENDPOINT=https://cloudflare-dns.com/dns-query
OBSCURA_EXIT_DOH_TIMEOUT=2.0
OBSCURA_EXIT_DENY_PRIVATE_IPS=true
# Comma-separated domain allow/deny lists
OBSCURA_EXIT_ALLOW_DOMAINS=
OBSCURA_EXIT_DENY_DOMAINS=

# ── Proxy Security ───────────────────────────────────────────────
# Require a Proxy-Token header when set
OBSCURA_PROXY_TOKEN=
OBSCURA_MAX_CONCURRENT_TUNNELS=50
OBSCURA_MAX_TUNNELS_PER_IP=10

# ── Channel Backpressure ─────────────────────────────────────────
OBSCURA_CHANNEL_QUEUE_MAX=100
OBSCURA_CHANNEL_WRITE_TIMEOUT=2.0
OBSCURA_CHANNEL_IDLE_CLOSE_SECONDS=60

# ── Encryption & Logging ─────────────────────────────────────────
# Set to true to reject legacy AES-CFB frames (onion-only mode)
OBSCURA_ONION_ONLY=false
# Set to true for structured JSON log output
OBSCURA_JSON_LOGS=false
# File logging (in addition to stderr). One file per process is created
# at ~/.obscura47/logs/{role}.log, where {role} is the entrypoint stem
# (e.g. tray_app.log, app.log). Rotates at 5MB x 5.
#   OBSCURA_LOG_DIR=~/.obscura47/logs        # directory for default file
#   OBSCURA_LOG_FILE=/path/to/single.log     # override exact path; set to
#                                            # "off" to disable file logging
#   OBSCURA_LOG_MAX_BYTES=5242880
#   OBSCURA_LOG_BACKUPS=5

# ── Minimal Audit Logs ───────────────────────────────────────────
# Keeps only operator/admin actions and exit egress summaries.
# Does not log client-origin metadata.
# OBSCURA_AUDIT_LOG_DIR=~/.obscura47/audit
OBSCURA_AUDIT_RETENTION_DAYS=14
OBSCURA_REGISTRY_ADMIN_AUDIT_ENABLED=true
# OBSCURA_REGISTRY_ADMIN_AUDIT_PATH=~/.obscura47/audit/registry_admin.jsonl
OBSCURA_EXIT_EGRESS_AUDIT_ENABLED=true
# OBSCURA_EXIT_EGRESS_AUDIT_PATH=~/.obscura47/audit/exit_egress.jsonl

# ── Diagnostic Event Stream (dev) ────────────────────────────────
# Structured timeline of what each node is doing - useful for tracking
# down flaky behaviour ("clearnet works, then doesn't, then obscura
# fails…") across multiple machines.
#
# Privacy note: enabling these records who picked which peer, which
# exit a request hit, which intro a host published. Safe for your own
# dev network; DISABLE in production by flipping these to 0.
#
# (1) Per-node JSONL written locally at ~/.obscura47/logs/{role}.jsonl.
#     Costs nothing and works out of the box - leave on while testing.
OBSCURA_DIAG=1

# (2) Also POST each event to the registry's /diag endpoint so all
#     nodes' events land in a single merged timeline. Off by default
#     because it needs a shared token (below). To turn on:
#       - set this to 1 on every node AND the registry
#       - set OBSCURA_DIAG_TOKEN to the same value everywhere
OBSCURA_DIAG_REGISTRY=0

# Shared secret authenticating /diag submissions. MUST match between
# the registry and every node that ships events. Generate one with:
#       python -c "import secrets; print(secrets.token_hex(24))"
# Leave empty to keep central collection off.
OBSCURA_DIAG_TOKEN=

# Tail the merged stream once collection is on:
#   python scripts/diag-tail.py
#   python scripts/diag-tail.py --filter event=origin_connect
#   python scripts/diag-tail.py --local proxy        # this node only
#
# Registry-side storage knobs (only meaningful on the registry host):
# OBSCURA_DIAG_PATH=~/.obscura47/diag.jsonl
# OBSCURA_DIAG_MAX_BYTES=52428800   # 50MB before the file rolls
# OBSCURA_DIAG_MAX_BATCH=100        # max events per /diag POST

# ── Persistent Key Paths ─────────────────────────────────────────
# Where node/exit ECC keypairs are stored (created automatically if missing)
# OBSCURA_NODE_KEY_PATH=~/.obscura47/node_key.pem
# OBSCURA_EXIT_KEY_PATH=~/.obscura47/exit_key.pem

# ── WebSocket Transport ──────────────────────────────────────────
# Nodes prefer WebSocket when peers advertise a ws_port.
OBSCURA_NODE_WS_PORT=5002
OBSCURA_EXIT_WS_PORT=6001
OBSCURA_PROXY_WS_RESP_PORT=9052
# Set to false to disable WebSocket preference and use TCP only
OBSCURA_PREFER_WEBSOCKET=true

# ── Advertised Host (multi-node behind one NAT) ──────────────────
# By default the registry records each peer under its public IP. If
# two machines on the same home/office network both run a node, they
# share the same public IP and clobber each other's registration
# (peer_id = host:port). Set an explicit advertised host on each
# machine to give them distinct peer IDs.
#
# Pick ONE of these strategies per machine:
#
#  a) LAN IP - works for clients on the same network. Remote internet
#     clients cannot reach this node. Best for home/dev setups.
#  b) A second public IP or a DNS name that resolves to this machine
#     specifically (e.g. dyndns hostname per box).
#
# Example - Windows node sharing a LAN with a Mac node:
#   OBSCURA_NODE_ADVERTISED_HOST=192.168.1.86
# Find your Windows LAN IP with: ipconfig  (look for IPv4 Address)
# Find your macOS LAN IP with:   ipconfig getifaddr en0
#
# OBSCURA_ADVERTISED_HOST applies to both node and exit unless one of
# the role-specific vars below is set.
# OBSCURA_ADVERTISED_HOST=
# OBSCURA_NODE_ADVERTISED_HOST=
# OBSCURA_EXIT_ADVERTISED_HOST=

# ── Registry Persistence ─────────────────────────────────────────
# SQLite database file for peer storage
OBSCURA_REGISTRY_DB_PATH=registry.db
# Max requests per minute per IP to the registry
OBSCURA_REGISTRY_RATE_LIMIT=60

# ── Registry Admin Settings (operator only) ─────────────────────
# These are only for administering the shared registry.
# Normal contributors should leave them unset.
OBSCURA_REGISTRY_ADMIN_KEY=
# Either set the admin public key inline or point to a local PEM file.
# OBSCURA_ADMIN_PUB_PEM=-----BEGIN PUBLIC KEY-----...
# OBSCURA_ADMIN_PUB_PEM_PATH=~/.obscura47/admin_pub.pem

# ── TLS ──────────────────────────────────────────────────────────
# Registry server: serve https:// with a cert and key.
# OBSCURA_REGISTRY_TLS_CERT=/etc/obscura/registry.crt
# OBSCURA_REGISTRY_TLS_KEY=/etc/obscura/registry.key
# WebSocket transport: serve wss:// on node/exit ws ports.
# OBSCURA_WS_TLS_CERT=/etc/letsencrypt/live/db.monmedjs.com/fullchain.pem
# OBSCURA_WS_TLS_KEY=/etc/letsencrypt/live/db.monmedjs.com/privkey.pem

# Client-side verification. Set to false only for dev/self-signed certs.
OBSCURA_TLS_VERIFY=true
