[Unit]
Description=Obscura47 Relay Node (dedicated)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=obscura
Group=obscura
WorkingDirectory=/opt/obscura47
ExecStart=/opt/obscura47/venv/bin/python join_network.py node
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/var/lib/obscura47
PrivateTmp=yes

# Environment
EnvironmentFile=/opt/obscura47/.env

[Install]
WantedBy=multi-user.target
